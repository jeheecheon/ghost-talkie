{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["build/**", "dist/**", ".output/**"],
      "env": ["BASE_PATH", "REOWN_PROJECT_ID", "ENABLED_FEATURES", "NOTIFICATION_SOUND_URL"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "lint": {
      "outputs": []
    },
    "lint:fix": {
      "cache": false
    }
  }
}
